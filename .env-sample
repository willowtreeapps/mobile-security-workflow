# Mobile DAST — Credential Template
# Copy this file to .env and fill in your values.
# .env is gitignored and never committed.
# Per-app overrides: .env.<package>  (e.g. .env.owasp.sat.agoat)

# ── Required for login / registration flows ───────────────────────────────────
USER_NAME=
EMAIL=
PASSWORD=

# ── Optional extras (fill only if the target app uses them) ──────────────────
PIN=
OTP=
PHONE=

# ── Network / backend overrides ───────────────────────────────────────────────
# API_BASE_URL=https://staging.example.com

# ── App-specific extras ───────────────────────────────────────────────────────
# Any EXTRA_<NAME>=<value> pair will be substituted into form fields by name match.
# Examples:
# EXTRA_INVITE_CODE=ABC123
# EXTRA_PROMO_CODE=WELCOME10
